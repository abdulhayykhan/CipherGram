<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Primary Application Theme -->
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/elegant_background</item>
        <item name="android:statusBarColor">@color/elegant_background</item>
        <item name="android:navigationBarColor">@color/elegant_background</item>
    </style>

    <!-- Theme to use during Cold Start under Android 12+ (API 31) Splash Screen API -->
    <style name="Theme.CipherGram.Splash" parent="Theme.MyApplication">
        <!-- Design setup using native platform 12+ splash features -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/elegant_background</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@color/elegant_background</item>

        <!-- Pre-Android 12 solid fallback layout using launcher backgrounds -->
        <item name="android:windowBackground">@drawable/ic_launcher_background</item>
    </style>
</resources>
